# Copy this file to secrets.toml and fill in your real values.
# secrets.toml is .gitignored — never commit it.

[sources.cta_train]
api_key = "YOUR_CTA_TRAIN_TRACKER_API_KEY"   # https://www.transitchicago.com/developers/traintrackerapply/

[destination.snowflake.credentials]
database = "CTA_DB"
password = "YOUR_SNOWFLAKE_PASSWORD"
username = "YOUR_SNOWFLAKE_USER"
host = "YOUR_ACCOUNT.snowflakecomputing.com"   # e.g. abc12345.us-east-1
role = "YOUR_ROLE"
warehouse = "COMPUTE_WH"
